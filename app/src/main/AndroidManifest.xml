<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Permisos -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />
    <uses-permission android:name="android.permission.USE_FINGERPRINT" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Feature de cámara (opcional) -->
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.TechMaintenance"
        tools:targetApi="31">

        <activity
            android:name=".activities.DashboardAdminActivity"
            android:exported="false"
            android:screenOrientation="sensor"
            android:configChanges="orientation|screenSize|screenLayout" />

        <!-- SplashActivity - Pantalla de inicio -->
        <activity
            android:name=".activities.SplashActivity"
            android:exported="true"
            android:screenOrientation="sensor"
            android:configChanges="orientation|screenSize|screenLayout"
            android:theme="@style/Theme.TechMaintenance">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- LoginActivity -->
        <activity
            android:name=".activities.LoginActivity"
            android:exported="false"
            android:screenOrientation="sensor"
            android:configChanges="orientation|screenSize|screenLayout"
            android:windowSoftInputMode="adjustResize" />

        <!-- MainActivity (temporal) -->
        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|screenLayout" />

        <activity
            android:name=".RecuperarPasswordActivity"
            android:screenOrientation="sensor"
            android:configChanges="orientation|screenSize|screenLayout"
            android:exported="false" />

        <activity
            android:name=".activities.DashboardTecnicoActivity"
            android:exported="false"
            android:screenOrientation="sensor"
            android:configChanges="orientation|screenSize|screenLayout"
            android:theme="@style/Theme.TechMaintenance"/>

        <activity
            android:name=".activities.ListaClientesActivity"
            android:exported="false"
            android:screenOrientation="sensor"
            android:configChanges="orientation|screenSize|screenLayout"/>

        <activity
            android:name=".activities.AgregarEditarClienteActivity"
            android:exported="false"
            android:screenOrientation="sensor"
            android:configChanges="orientation|screenSize|screenLayout"
            android:windowSoftInputMode="adjustResize"/>

        <activity
            android:name=".activities.DetalleClienteActivity"
            android:exported="false"
            android:screenOrientation="sensor"
            android:configChanges="orientation|screenSize|screenLayout"/>

        <!-- Gestión de Equipos -->
        <activity
            android:name=".activities.ListaEquiposActivity"
            android:exported="false"
            android:screenOrientation="sensor"
            android:configChanges="orientation|screenSize|screenLayout"/>

        <activity
            android:name=".activities.AgregarEditarEquipoActivity"
            android:exported="false"
            android:screenOrientation="sensor"
            android:configChanges="orientation|screenSize|screenLayout"
            android:windowSoftInputMode="adjustResize"/>

        <activity
            android:name=".activities.DetalleEquipoActivity"
            android:exported="false"
            android:screenOrientation="sensor"
            android:configChanges="orientation|screenSize|screenLayout"/>

        <!-- Gestión de Técnicos (Solo Admin) -->
        <activity
            android:name=".activities.AdministrarTecnicosActivity"
            android:exported="false"
            android:screenOrientation="sensor"
            android:configChanges="orientation|screenSize|screenLayout"/>

        <activity
            android:name=".activities.CrearEditarTecnicoActivity"
            android:exported="false"
            android:screenOrientation="sensor"
            android:configChanges="orientation|screenSize|screenLayout"
            android:windowSoftInputMode="adjustResize"/>

        <activity
            android:name=".activities.PerfilAdminActivity"
            android:exported="false"
            android:screenOrientation="sensor"
            android:configChanges="orientation|screenSize|screenLayout"
            android:windowSoftInputMode="adjustResize"/>

        <activity
            android:name=".activities.PerfilTecnicoActivity"
            android:exported="false"
            android:screenOrientation="sensor"
            android:configChanges="orientation|screenSize|screenLayout"
            android:windowSoftInputMode="adjustResize"/>

        <activity
            android:name=".activities.CambiarPasswordActivity"
            android:exported="false"
            android:screenOrientation="sensor"
            android:configChanges="orientation|screenSize|screenLayout"
            android:windowSoftInputMode="adjustResize"/>

        <!-- Gestión de Mantenimientos -->
        <activity
            android:name=".activities.ListaMantenimientosActivity"
            android:exported="false"
            android:screenOrientation="sensor"
            android:configChanges="orientation|screenSize|screenLayout"/>

        <activity
            android:name=".activities.CrearMantenimientoActivity"
            android:exported="false"
            android:screenOrientation="sensor"
            android:configChanges="orientation|screenSize|screenLayout"
            android:windowSoftInputMode="adjustResize"/>

        <activity
            android:name=".activities.DetalleMantenimientoActivity"
            android:exported="false"
            android:screenOrientation="sensor"
            android:configChanges="orientation|screenSize|screenLayout"
            android:windowSoftInputMode="adjustResize"/>

        <activity
            android:name=".activities.CompletarServicioActivity"
            android:exported="false"
            android:screenOrientation="sensor"
            android:configChanges="orientation|screenSize|screenLayout"/>

        <activity
            android:name=".activities.ValidarServicioActivity"
            android:exported="true"
            android:screenOrientation="sensor"
            android:configChanges="orientation|screenSize|screenLayout">
            <intent-filter>
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data
                    android:scheme="https"
                    android:host="techmaintenance.web.app"
                    android:pathPrefix="/validar"/>
            </intent-filter>
        </activity>

        <activity
            android:name=".activities.ValidacionClienteActivity"
            android:exported="false"
            android:screenOrientation="sensor"
            android:configChanges="orientation|screenSize|screenLayout"
            android:windowSoftInputMode="adjustResize"/>

        <!-- Calendario -->
        <activity
            android:name=".activities.CalendarioActivity"
            android:exported="false"
            android:screenOrientation="sensor"
            android:configChanges="orientation|screenSize|screenLayout"/>

        <!-- Reportes (Solo Admin) -->
        <activity
            android:name=".activities.ReportesActivity"
            android:exported="false"
            android:screenOrientation="sensor"
            android:configChanges="orientation|screenSize|screenLayout"/>

        <!-- Notificaciones -->
        <activity
            android:name=".activities.NotificacionesActivity"
            android:exported="false"
            android:screenOrientation="sensor"
            android:configChanges="orientation|screenSize|screenLayout"/>

        <!-- Firebase Cloud Messaging Service -->
        <service
            android:name=".services.MyFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- FileProvider para captura de fotos -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>