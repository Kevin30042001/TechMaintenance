<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cardNotificacion"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginTop="4dp"
    android:layout_marginBottom="4dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <!-- Icono según tipo de notificación -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardIcono"
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            android:layout_marginEnd="12dp">

            <ImageView
                android:id="@+id/ivIcono"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_notifications"
                app:tint="@color/white"
                tools:ignore="ContentDescription"/>

        </com.google.android.material.card.MaterialCardView>

        <!-- Contenido de la notificación -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Título -->
            <TextView
                android:id="@+id/tvTitulo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nueva asignación"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/primary_text"
                android:maxLines="1"
                android:ellipsize="end"
                tools:ignore="HardcodedText"/>

            <!-- Mensaje -->
            <TextView
                android:id="@+id/tvMensaje"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Te han asignado un nuevo mantenimiento"
                android:textSize="14sp"
                android:textColor="@color/secondary_text"
                android:maxLines="2"
                android:ellipsize="end"
                tools:ignore="HardcodedText"/>

            <!-- Tiempo transcurrido -->
            <TextView
                android:id="@+id/tvTiempo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Hace 5 minutos"
                android:textSize="12sp"
                android:textColor="@color/secondary_text"
                tools:ignore="HardcodedText"/>

        </LinearLayout>

        <!-- Indicador de no leída -->
        <View
            android:id="@+id/indicadorNoLeida"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="8dp"
            android:background="@drawable/circulo_notificacion_no_leida"
            android:visibility="visible"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
