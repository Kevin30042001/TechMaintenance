<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Técnico Principal -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Técnico Principal"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/primary"
        android:layout_marginBottom="8dp"/>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilTecnicoPrincipalReasignar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:hint="Seleccionar técnico principal"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">

        <AutoCompleteTextView
            android:id="@+id/actvTecnicoPrincipalReasignar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="none"/>

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Técnicos de Apoyo -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Técnicos de Apoyo"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/primary"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="(Opcional, máx. 3)"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"/>

    </LinearLayout>

    <!-- Mostrar técnicos de apoyo actuales -->
    <TextView
        android:id="@+id/tvTecnicosApoyoActuales"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Actuales: Ninguno"
        android:textSize="12sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="8dp"
        android:visibility="gone"/>

    <!-- Container dinámico para técnicos de apoyo -->
    <LinearLayout
        android:id="@+id/containerTecnicosApoyoReasignar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="8dp"/>

    <!-- Botón para agregar técnico de apoyo -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAgregarTecnicoApoyoReasignar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="+ Agregar Técnico de Apoyo"
        android:textSize="12sp"
        app:icon="@drawable/ic_add"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

</LinearLayout>
