<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Toolbar -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/primary"
            app:title="Nuevo Mantenimiento"
            app:titleTextColor="@android:color/white"
            app:navigationIcon="@drawable/ic_arrow_back_white" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Indicador de Pasos -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center">

        <TextView
            android:id="@+id/tvPaso1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="1. Cliente"
            android:textAlignment="center"
            android:textSize="12sp"
            android:textColor="@color/primary"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvPaso2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="2. Detalles"
            android:textAlignment="center"
            android:textSize="12sp"
            android:textColor="@color/secondary_text" />

        <TextView
            android:id="@+id/tvPaso3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="3. T\u00e9cnicos"
            android:textAlignment="center"
            android:textSize="12sp"
            android:textColor="@color/secondary_text" />

    </LinearLayout>

    <!-- Contenedor de Pasos (ViewFlipper) -->
    <ViewFlipper
        android:id="@+id/viewFlipper"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- PASO 1: Seleccionar Cliente y Equipo -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Cliente -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilCliente"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:startIconDrawable="@drawable/ic_business"
                    app:helperText="Requerido"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">

                    <AutoCompleteTextView
                        android:id="@+id/actvCliente"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Seleccionar Cliente"
                        android:inputType="none"
                        android:maxLines="1" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Equipos a mantener (Selección múltiple) -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Equipos a Mantener"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_text"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp"
                    android:drawableStart="@drawable/ic_computer"
                    android:drawablePadding="8dp"
                    android:gravity="center_vertical"/>

                <TextView
                    android:id="@+id/tvHelperEquipos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Selecciona cliente primero"
                    android:textSize="13sp"
                    android:textColor="@color/secondary_text"
                    android:layout_marginBottom="8dp"/>

                <!-- RecyclerView para equipos con checkboxes -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvEquipos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="200dp"
                    android:maxHeight="400dp"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone"/>

                <!-- Mensaje sin equipos -->
                <TextView
                    android:id="@+id/tvSinEquipos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Este cliente no tiene equipos registrados"
                    android:textSize="14sp"
                    android:textColor="@color/secondary_text"
                    android:textAlignment="center"
                    android:padding="32dp"
                    android:visibility="gone"/>

                <!-- Contador de equipos seleccionados -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardContador"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="@color/primary"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="2dp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tvContadorEquipos"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="0 equipos seleccionados"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@android:color/white"
                        android:padding="12dp"
                        android:gravity="center"
                        android:drawableStart="@drawable/ic_check_circle"
                        android:drawablePadding="8dp"/>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </ScrollView>

        <!-- PASO 2: Detalles del Mantenimiento -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Tipo -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilTipo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:startIconDrawable="@drawable/ic_build"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">

                    <AutoCompleteTextView
                        android:id="@+id/actvTipo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Tipo de Mantenimiento"
                        android:inputType="none"
                        android:maxLines="1" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Descripción -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilDescripcion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:startIconDrawable="@drawable/ic_edit"
                    app:counterEnabled="true"
                    app:counterMaxLength="500"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etDescripcion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Descripción del Servicio"
                        android:inputType="textMultiLine"
                        android:minLines="3"
                        android:maxLines="5"
                        android:maxLength="500"
                        android:gravity="top" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Fecha -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilFecha"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:startIconDrawable="@drawable/ic_calendar"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etFecha"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Fecha Programada"
                        android:inputType="none"
                        android:focusable="false"
                        android:maxLines="1" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Hora -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilHora"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:startIconDrawable="@drawable/ic_calendar"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etHora"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Hora Programada"
                        android:inputType="none"
                        android:focusable="false"
                        android:maxLines="1" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Prioridad -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilPrioridad"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:startIconDrawable="@drawable/ic_star"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">

                    <AutoCompleteTextView
                        android:id="@+id/actvPrioridad"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Prioridad"
                        android:inputType="none"
                        android:maxLines="1" />

                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

        </ScrollView>

        <!-- PASO 3: Asignar Técnicos -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Técnico Principal -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilTecnicoPrincipal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:startIconDrawable="@drawable/ic_person"
                    app:helperText="Requerido"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">

                    <AutoCompleteTextView
                        android:id="@+id/actvTecnicoPrincipal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="T\u00e9cnico Principal"
                        android:inputType="none"
                        android:maxLines="1" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Técnicos de Apoyo (Opcional) -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="T\u00e9cnicos de Apoyo (Opcional)"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_text"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="M\u00e1ximo 3 t\u00e9cnicos de apoyo"
                    android:textSize="12sp"
                    android:textColor="@color/secondary_text"
                    android:layout_marginBottom="16dp" />

                <!-- Aquí irán los técnicos de apoyo dinámicamente -->
                <LinearLayout
                    android:id="@+id/containerTecnicosApoyo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="16dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAgregarTecnicoApoyo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Agregar T\u00e9cnico de Apoyo"
                    app:icon="@drawable/ic_add"
                    app:backgroundTint="@android:color/transparent"
                    app:strokeColor="@color/primary"
                    app:strokeWidth="1dp"
                    android:textColor="@color/primary"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

            </LinearLayout>

        </ScrollView>

    </ViewFlipper>

    <!-- Botones de Navegación -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="@android:color/white"
        android:elevation="4dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAnterior"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="ANTERIOR"
            android:visibility="gone"
            app:backgroundTint="@android:color/transparent"
            app:strokeColor="@color/secondary_text"
            app:strokeWidth="1dp"
            android:textColor="@color/secondary_text"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSiguiente"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="SIGUIENTE"
            app:backgroundTint="@color/primary"
            android:textColor="@android:color/white" />

    </LinearLayout>

</LinearLayout>
