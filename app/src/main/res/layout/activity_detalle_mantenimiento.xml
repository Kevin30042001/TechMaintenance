<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_color">

    <!-- AppBar -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/primary"
            app:title="@string/detalle_mantenimiento"
            app:titleTextColor="@color/white"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationIconTint="@color/white"/>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Contenido con scroll -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ProgressBar de carga -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="16dp"
                android:visibility="gone"/>

            <!-- Header: Chips de Estado y Prioridad -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_horizontal"
                android:layout_marginBottom="16dp"
                android:spacing="8dp">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipEstado"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/estado"
                    android:layout_margin="4dp"
                    app:chipBackgroundColor="@color/info"
                    app:chipStrokeColor="@color/info"
                    android:textColor="@color/white"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipPrioridad"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/prioridad"
                    android:layout_margin="4dp"
                    app:chipBackgroundColor="@color/info"
                    app:chipStrokeColor="@color/info"
                    android:textColor="@color/white"/>

            </LinearLayout>

            <!-- SECCIÓN 1: Tarjeta de Equipo -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/card_light">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Título de sección -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/equipo_titulo"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:layout_marginBottom="12dp"/>

                    <!-- Imagen del Equipo -->
                    <ImageView
                        android:id="@+id/ivEquipo"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:scaleType="centerCrop"
                        android:contentDescription="@string/foto_equipo"
                        android:background="@color/background_secondary"
                        android:layout_marginBottom="12dp"/>

                    <!-- Marca y Modelo -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/marca_modelo"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"/>

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvMarcaModelo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/sin_especificar"
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="12dp"/>

                    <!-- Número de Serie -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/numero_serie"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"/>

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvNumeroSerie"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/sin_especificar"
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="12dp"/>

                    <!-- Tipo de Equipo -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/tipo_equipo"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"/>

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvTipoEquipo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/sin_especificar"
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="12dp"/>

                    <!-- Ubicación Específica -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/ubicacion_especifica"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"/>

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvUbicacionEquipo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/sin_especificar"
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- SECCIÓN 2: Tarjeta de Cliente -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/card_light">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Título de sección -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/cliente_titulo"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:layout_marginBottom="12dp"/>

                    <!-- Nombre de la Empresa -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/nombre_empresa"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"/>

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvNombreEmpresa"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/sin_especificar"
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="12dp"/>

                    <!-- Contacto -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/contacto_principal"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"/>

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvContacto"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/sin_especificar"
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="12dp"/>

                    <!-- Teléfono del Cliente -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/telefono_contacto"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"/>

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvTelefonoCliente"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/sin_especificar"
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="12dp"/>

                    <!-- Dirección del Cliente -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/direccion_completa"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"/>

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvDireccionCliente"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/sin_especificar"
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="16dp"/>

                    <!-- Botones de Contacto -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:spacing="8dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnLlamar"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/llamar"
                            app:icon="@drawable/ic_phone"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnEmail"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/email"
                            app:icon="@drawable/ic_email"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnMapa"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/mapa"
                            app:icon="@drawable/ic_location"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- SECCIÓN 3: Detalles del Servicio -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/card_light">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Título de sección -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/detalles_servicio"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:layout_marginBottom="12dp"/>

                    <!-- Tipo de Mantenimiento -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/tipo_mantenimiento"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"/>

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvTipo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/sin_especificar"
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="12dp"/>

                    <!-- Descripción del Servicio -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/descripcion_servicio"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"/>

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvDescripcion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/sin_especificar"
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="12dp"/>

                    <!-- Fecha Programada -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/fecha_programada"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"/>

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvFechaProgramada"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/sin_especificar"
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="12dp"/>

                    <!-- Fecha de Inicio -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/fecha_inicio"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"/>

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvFechaInicio"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/sin_especificar"
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="12dp"/>

                    <!-- Fecha de Finalización -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/fecha_finalizacion"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"/>

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvFechaFin"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/sin_especificar"
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="12dp"/>

                    <!-- Duración del Servicio -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/duracion_servicio"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"/>

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvDuracion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/sin_especificar"
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- SECCIÓN 4: Equipo de Trabajo -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/card_light">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Título de sección -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/equipo_trabajo"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:layout_marginBottom="12dp"/>

                    <!-- Técnico Principal -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/tecnico_principal"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"/>

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvTecnicoPrincipal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/sin_especificar"
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="12dp"/>

                    <!-- Técnicos de Apoyo -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/tecnicos_apoyo"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"/>

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvTecnicosApoyo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/sin_especificar"
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- SECCIÓN 5: Observaciones Técnicas -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/card_light">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Título de sección -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/observaciones_tecnicas"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:layout_marginBottom="12dp"/>

                    <!-- Input de Observaciones -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilObservaciones"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:hint="@string/observaciones_servicio"
                        app:counterEnabled="true"
                        app:counterMaxLength="500"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etObservaciones"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textMultiLine|textCapSentences"
                            android:minLines="3"
                            android:maxLines="6"
                            android:maxLength="500"
                            android:gravity="start|top"/>

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Botón Guardar Observaciones -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnGuardarObservaciones"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/guardar_observaciones"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- SECCIÓN 6: Evidencias Fotográficas -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/card_light">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Título de sección -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/evidencias_fotograficas"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary"/>

                        <TextView
                            android:id="@+id/tvNumFotos"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/num_fotos"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"/>

                    </LinearLayout>

                    <!-- Galería de fotos (HorizontalScrollView) -->
                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:scrollbars="none">

                        <LinearLayout
                            android:id="@+id/containerFotos"
                            android:layout_width="wrap_content"
                            android:layout_height="120dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:spacing="8dp"/>

                    </HorizontalScrollView>

                    <!-- Botón Agregar Foto -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAgregarFoto"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/agregar_foto"
                        app:icon="@drawable/ic_camera_alt"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- SECCIÓN 7: Validación del Cliente -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/layoutValidacion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/card_light">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Título de sección -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/validacion_cliente"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:layout_marginBottom="12dp"/>

                    <!-- Código de Validación -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/codigo_validacion"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"/>

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvCodigoValidacion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/sin_especificar"
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp"/>

                    <!-- Estado de Validación -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/estado_validacion"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"/>

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvEstadoValidacion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/sin_especificar"
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="12dp"/>

                    <!-- Calificación del Cliente -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/calificacion_cliente"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"/>

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvCalificacion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/sin_especificar"
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="12dp"/>

                    <!-- Comentario del Cliente -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/comentario_cliente"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"/>

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvComentarioCliente"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/sin_especificar"
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- SECCIÓN 8: Botones de Acción - Admin -->
            <LinearLayout
                android:id="@+id/layoutBotonesAdmin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="16dp"
                android:spacing="8dp"
                android:visibility="gone">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEditar"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/editar"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnReasignar"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/reasignar"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCancelarAdmin"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/cancelar"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

            </LinearLayout>

            <!-- Botón Eliminar (Solo Admin) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEliminarMantenimiento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Eliminar Mantenimiento"
                android:textColor="@color/white"
                app:icon="@drawable/ic_delete"
                app:iconTint="@color/white"
                app:iconGravity="start"
                app:backgroundTint="@color/error"
                android:layout_marginBottom="16dp"
                android:visibility="gone"
                style="@style/Widget.MaterialComponents.Button"/>

            <!-- SECCIÓN 9: Botones de Acción - Técnico Principal -->
            <LinearLayout
                android:id="@+id/layoutBotonesTecnicoPrincipal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="16dp"
                android:spacing="8dp"
                android:visibility="gone">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnIniciarServicio"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/iniciar_servicio"
                    style="@style/Widget.MaterialComponents.Button"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCompletarServicio"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/completar_servicio"
                    style="@style/Widget.MaterialComponents.Button"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCancelarTecnico"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/cancelar"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

            </LinearLayout>

            <!-- SECCIÓN 10: Botones de Acción - Técnico de Apoyo -->
            <LinearLayout
                android:id="@+id/layoutBotonesTecnicoApoyo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="16dp"
                android:visibility="gone"/>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
