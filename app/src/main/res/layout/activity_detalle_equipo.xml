<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:id="@+id/collapsingToolbar"
            android:layout_width="match_parent"
            android:layout_height="280dp"
            app:layout_scrollFlags="scroll|exitUntilCollapsed"
            app:contentScrim="@color/primary"
            app:expandedTitleMarginStart="16dp"
            app:expandedTitleMarginBottom="16dp">

            <!-- Foto del equipo -->
            <ImageView
                android:id="@+id/ivFotoEquipo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_computer"
                app:layout_collapseMode="parallax"
                android:contentDescription="Fotografía del equipo"
                tools:ignore="HardcodedText"/>

            <!-- Overlay oscuro para mejorar legibilidad -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/black"
                android:alpha="0.3"
                app:layout_collapseMode="parallax"/>

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                app:layout_collapseMode="pin"
                app:popupTheme="@style/ThemeOverlay.AppCompat.Light"
                app:navigationIcon="@drawable/ic_arrow_back"/>

        </com.google.android.material.appbar.CollapsingToolbarLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Card: Información del Cliente -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cliente Propietario"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:layout_marginBottom="12dp"
                        tools:ignore="HardcodedText"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_business"
                            android:padding="8dp"
                            android:background="@drawable/circle_shape"
                            app:tint="@color/primary"
                            android:contentDescription="Icono cliente"
                            tools:ignore="HardcodedText"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">

                            <TextView
                                android:id="@+id/tvNombreCliente"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Nombre del Cliente"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/primary_text"
                                tools:ignore="HardcodedText"/>

                            <TextView
                                android:id="@+id/tvContactoCliente"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Contacto"
                                android:textSize="14sp"
                                android:textColor="@color/secondary_text"
                                android:layout_marginTop="2dp"
                                tools:ignore="HardcodedText"/>

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Card: Datos Técnicos -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Datos Técnicos"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:layout_marginBottom="16dp"
                        tools:ignore="HardcodedText"/>

                    <!-- Tipo -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tipo de Equipo"
                        android:textSize="13sp"
                        android:textColor="@color/secondary_text"
                        android:layout_marginBottom="4dp"
                        tools:ignore="HardcodedText"/>

                    <TextView
                        android:id="@+id/tvTipo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Laptop"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary_text"
                        android:layout_marginBottom="12dp"
                        tools:ignore="HardcodedText"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider"
                        android:layout_marginBottom="12dp"/>

                    <!-- Marca -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Marca"
                        android:textSize="13sp"
                        android:textColor="@color/secondary_text"
                        android:layout_marginBottom="4dp"
                        tools:ignore="HardcodedText"/>

                    <TextView
                        android:id="@+id/tvMarca"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dell"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary_text"
                        android:layout_marginBottom="12dp"
                        tools:ignore="HardcodedText"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider"
                        android:layout_marginBottom="12dp"/>

                    <!-- Modelo -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Modelo"
                        android:textSize="13sp"
                        android:textColor="@color/secondary_text"
                        android:layout_marginBottom="4dp"
                        tools:ignore="HardcodedText"/>

                    <TextView
                        android:id="@+id/tvModelo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Latitude 5420"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary_text"
                        android:layout_marginBottom="12dp"
                        tools:ignore="HardcodedText"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider"
                        android:layout_marginBottom="12dp"/>

                    <!-- Número de Serie -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Número de Serie"
                        android:textSize="13sp"
                        android:textColor="@color/secondary_text"
                        android:layout_marginBottom="4dp"
                        tools:ignore="HardcodedText"/>

                    <TextView
                        android:id="@+id/tvNumeroSerie"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DL-2025-001"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary_text"
                        tools:ignore="HardcodedText"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Card: Ubicación y Estado -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ubicación y Estado"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:layout_marginBottom="16dp"
                        tools:ignore="HardcodedText"/>

                    <!-- Ubicación -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ubicación"
                        android:textSize="13sp"
                        android:textColor="@color/secondary_text"
                        android:layout_marginBottom="4dp"
                        tools:ignore="HardcodedText"/>

                    <TextView
                        android:id="@+id/tvUbicacion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Oficina 205"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary_text"
                        android:layout_marginBottom="12dp"
                        tools:ignore="HardcodedText"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider"
                        android:layout_marginVertical="12dp"/>

                    <!-- Estado -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Estado"
                            android:textSize="13sp"
                            android:textColor="@color/secondary_text"
                            tools:ignore="HardcodedText"/>

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipEstado"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Operativo"
                            android:textSize="12sp"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            tools:ignore="HardcodedText"/>

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider"
                        android:layout_marginVertical="12dp"/>

                    <!-- Fecha de Adquisición -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fecha de Adquisición"
                        android:textSize="13sp"
                        android:textColor="@color/secondary_text"
                        android:layout_marginBottom="4dp"
                        tools:ignore="HardcodedText"/>

                    <TextView
                        android:id="@+id/tvFechaAdquisicion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="14/11/2025"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary_text"
                        tools:ignore="HardcodedText"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Card: Estadísticas -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Estadísticas"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:layout_marginBottom="16dp"
                        tools:ignore="HardcodedText"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- Total Mantenimientos -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="12dp">

                            <TextView
                                android:id="@+id/tvTotalMantenimientos"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="28sp"
                                android:textStyle="bold"
                                android:textColor="@color/primary"
                                tools:ignore="HardcodedText"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Mantenimientos"
                                android:textSize="12sp"
                                android:textColor="@color/secondary_text"
                                android:layout_marginTop="4dp"
                                tools:ignore="HardcodedText"/>

                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="match_parent"
                            android:background="@color/divider"/>

                        <!-- Último Mantenimiento -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="12dp">

                            <TextView
                                android:id="@+id/tvUltimoMantenimiento"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="N/A"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/primary"
                                android:gravity="center"
                                tools:ignore="HardcodedText"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Último"
                                android:textSize="12sp"
                                android:textColor="@color/secondary_text"
                                android:layout_marginTop="4dp"
                                tools:ignore="HardcodedText"/>

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Card: Fechas de Registro -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="80dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Información del Registro"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:layout_marginBottom="16dp"
                        tools:ignore="HardcodedText"/>

                    <!-- Fecha de Registro -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fecha de Registro"
                        android:textSize="13sp"
                        android:textColor="@color/secondary_text"
                        android:layout_marginBottom="4dp"
                        tools:ignore="HardcodedText"/>

                    <TextView
                        android:id="@+id/tvFechaRegistro"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="14/11/2025 12:46"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary_text"
                        android:layout_marginBottom="12dp"
                        tools:ignore="HardcodedText"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider"
                        android:layout_marginBottom="12dp"/>

                    <!-- Última Actualización -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Última Actualización"
                        android:textSize="13sp"
                        android:textColor="@color/secondary_text"
                        android:layout_marginBottom="4dp"
                        tools:ignore="HardcodedText"/>

                    <TextView
                        android:id="@+id/tvUltimaActualizacion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="N/A"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary_text"
                        tools:ignore="HardcodedText"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Card: Historial de Mantenimientos -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardHistorial"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp"
                        android:paddingBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Historial de Mantenimientos"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary"
                            tools:ignore="HardcodedText"/>

                        <TextView
                            android:id="@+id/tvContadorHistorial"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/secondary_text"
                            tools:ignore="HardcodedText"/>

                    </LinearLayout>

                    <!-- Mensaje sin historial -->
                    <TextView
                        android:id="@+id/tvSinHistorial"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Este equipo aún no tiene mantenimientos registrados"
                        android:textSize="14sp"
                        android:textColor="@color/secondary_text"
                        android:textAlignment="center"
                        android:padding="32dp"
                        android:visibility="gone"
                        tools:visibility="visible"
                        tools:ignore="HardcodedText"/>

                    <!-- ProgressBar de carga -->
                    <ProgressBar
                        android:id="@+id/progressBarHistorial"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_margin="32dp"
                        android:visibility="gone"/>

                    <!-- RecyclerView con Timeline -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerHistorial"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        android:paddingBottom="8dp"
                        tools:listitem="@layout/item_mantenimiento_timeline"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Card: Botón Eliminar (solo para admin) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="80dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEliminar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Eliminar Equipo"
                        android:textColor="@color/white"
                        app:icon="@drawable/ic_delete"
                        app:iconTint="@color/white"
                        app:iconGravity="start"
                        app:backgroundTint="@color/error"
                        android:visibility="gone"
                        style="@style/Widget.MaterialComponents.Button"
                        tools:visibility="visible"
                        tools:ignore="HardcodedText"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- FAB Editar (solo para admin) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabEditar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:src="@drawable/ic_edit"
        app:tint="@color/white"
        android:contentDescription="Editar equipo"
        tools:ignore="HardcodedText"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
