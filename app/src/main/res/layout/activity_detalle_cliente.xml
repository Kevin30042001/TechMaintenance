<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_color">

    <!-- AppBar -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/primary"
            app:title="@string/detalle_cliente"
            app:titleTextColor="@color/white"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationIconTint="@color/white"/>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Contenido -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Card principal con datos -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Nombre de la empresa -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🏢"
                        android:textSize="32sp"
                        android:layout_gravity="center"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/tvNombreEmpresa"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Corporación XYZ"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary_text"
                        android:textAlignment="center"
                        android:layout_marginBottom="24dp"
                        tools:ignore="HardcodedText"/>

                    <!-- Separador -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider_color"
                        android:layout_marginBottom="16dp"/>

                    <!-- Contacto Principal -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/contacto_principal"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:layout_marginBottom="12dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="👤"
                            android:textSize="20sp"
                            android:layout_marginEnd="8dp"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvNombreContacto"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Juan Pérez"
                                android:textSize="16sp"
                                android:textColor="@color/primary_text"
                                tools:ignore="HardcodedText"/>

                            <TextView
                                android:id="@+id/tvCargoContacto"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Gerente de TI"
                                android:textSize="14sp"
                                android:textColor="@color/secondary_text"
                                tools:ignore="HardcodedText"/>

                        </LinearLayout>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📧"
                            android:textSize="20sp"
                            android:layout_marginEnd="8dp"/>

                        <TextView
                            android:id="@+id/tvEmailContacto"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="juan.perez@corporacion.com"
                            android:textSize="15sp"
                            android:textColor="@color/primary"
                            android:autoLink="email"
                            tools:ignore="HardcodedText"/>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="4dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📞"
                            android:textSize="20sp"
                            android:layout_marginEnd="8dp"/>

                        <TextView
                            android:id="@+id/tvTelefonoContacto"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="+503 7777-8888"
                            android:textSize="15sp"
                            android:textColor="@color/primary"
                            android:autoLink="phone"
                            tools:ignore="HardcodedText"/>

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutTelefonoAlternativo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📞"
                            android:textSize="20sp"
                            android:layout_marginEnd="8dp"/>

                        <TextView
                            android:id="@+id/tvTelefonoAlternativo"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="+503 6666-7777"
                            android:textSize="15sp"
                            android:textColor="@color/secondary_text"
                            tools:ignore="HardcodedText"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="(Alternativo)"
                            android:textSize="12sp"
                            android:textColor="@color/secondary_text"/>

                    </LinearLayout>

                    <!-- Separador -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider_color"
                        android:layout_marginBottom="16dp"/>

                    <!-- Ubicación -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/ubicacion_cliente"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:layout_marginBottom="12dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="start"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📍"
                            android:textSize="20sp"
                            android:layout_marginEnd="8dp"
                            android:layout_marginTop="2dp"/>

                        <TextView
                            android:id="@+id/tvDireccion"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Edificio Torre 1, Piso 3, Col. Escalón, San Salvador"
                            android:textSize="15sp"
                            android:textColor="@color/primary_text"
                            tools:ignore="HardcodedText"/>

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutReferencia"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="start"
                        android:layout_marginBottom="16dp"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🗺️"
                            android:textSize="20sp"
                            android:layout_marginEnd="8dp"
                            android:layout_marginTop="2dp"/>

                        <TextView
                            android:id="@+id/tvReferenciaDireccion"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Frente a Metrocentro, portón verde"
                            android:textSize="14sp"
                            android:textColor="@color/secondary_text"
                            android:textStyle="italic"
                            tools:ignore="HardcodedText"/>

                    </LinearLayout>

                    <!-- Separador -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider_color"
                        android:layout_marginBottom="16dp"/>

                    <!-- Estadísticas -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/estadisticas"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:layout_marginBottom="12dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💻 "
                            android:textSize="18sp"/>

                        <TextView
                            android:id="@+id/tvTotalEquipos"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="15 equipos registrados"
                            android:textSize="15sp"
                            android:textColor="@color/primary_text"
                            tools:ignore="HardcodedText"/>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📅 "
                            android:textSize="18sp"/>

                        <TextView
                            android:id="@+id/tvFechaRegistro"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Registrado: 15/01/2025"
                            android:textSize="15sp"
                            android:textColor="@color/secondary_text"
                            tools:ignore="HardcodedText"/>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Botones de acción -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <!-- ✅ Botón Editar -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEditarCliente"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/editar_cliente"
                    app:icon="@android:drawable/ic_menu_edit"
                    app:iconGravity="start"
                    android:layout_marginBottom="8dp"/>

                <!-- ✅ Botón Ver Equipos -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnVerEquipos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/ver_equipos"
                    app:icon="@android:drawable/ic_menu_view"
                    app:iconGravity="start"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_marginBottom="8dp"/>

                <!-- ⭐ NUEVO: Botón Eliminar Cliente -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEliminarCliente"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/eliminar_cliente"
                    android:backgroundTint="@color/error"
                    android:textColor="@color/white"
                    app:icon="@android:drawable/ic_menu_delete"
                    app:iconTint="@color/white"
                    app:iconGravity="start"/>

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>