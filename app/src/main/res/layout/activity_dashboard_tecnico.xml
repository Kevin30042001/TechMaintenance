<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_color"
    tools:context=".activities.DashboardTecnicoActivity">

    <!-- AppBar con Toolbar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:elevation="4dp"
        app:elevation="4dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/primary"
            app:titleTextColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/mi_dashboard"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:textStyle="bold"/>

                <!-- Botón de notificaciones con badge -->
                <FrameLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="8dp">

                    <ImageButton
                        android:id="@+id/btnNotificaciones"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Notificaciones"
                        android:src="@drawable/ic_notifications"
                        app:tint="@color/white"/>

                    <!-- Badge de notificaciones no leídas -->
                    <TextView
                        android:id="@+id/badgeNotificaciones"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_gravity="top|end"
                        android:layout_marginTop="6dp"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/badge_background"
                        android:gravity="center"
                        android:text="5"
                        android:textColor="@color/white"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:visibility="gone"
                        tools:visibility="visible"/>

                </FrameLayout>

                <ImageView
                    android:id="@+id/imgPerfil"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/ic_person"
                    android:contentDescription="@string/perfil"
                    android:scaleType="centerCrop" />

            </LinearLayout>

        </com.google.android.material.appbar.MaterialToolbar>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Contenido principal con Scroll -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:layout_marginBottom="60dp"
        android:clipToPadding="false"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:clipToPadding="false">

            <!-- SECCIÓN 1: SALUDO PERSONALIZADO -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/primary">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvSaludo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Hola, Roberto"
                            android:textColor="@color/white"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            tools:ignore="HardcodedText"/>

                        <TextView
                            android:id="@+id/tvServiciosHoy"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tienes 3 servicios hoy"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:layout_marginTop="4dp"
                            tools:ignore="HardcodedText"/>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="8dp">

                            <View
                                android:layout_width="8dp"
                                android:layout_height="8dp"
                                android:background="@drawable/circle_shape"
                                android:backgroundTint="#4CAF50"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/activo"
                                android:textColor="@color/white"
                                android:textSize="12sp"
                                android:layout_marginStart="6dp"/>

                        </LinearLayout>

                    </LinearLayout>

                    <ImageView
                        android:id="@+id/imgPerfilGrande"
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        android:background="@drawable/circle_shape"
                        android:backgroundTint="@color/white"
                        android:padding="4dp"
                        android:src="@drawable/ic_person"
                        android:contentDescription="@string/foto_perfil"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- SECCIÓN 2: MIS TAREAS DE HOY -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/mis_tareas_hoy"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_text"/>

                <TextView
                    android:id="@+id/tvVerTodasTareas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ver_todas"
                    android:textSize="14sp"
                    android:textColor="@color/primary"
                    android:textStyle="bold"
                    android:padding="8dp"/>

            </LinearLayout>

            <!-- ProgressBar de carga -->
            <ProgressBar
                android:id="@+id/progressBarTareas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginVertical="32dp"
                android:visibility="gone"/>

            <!-- Mensaje sin tareas -->
            <TextView
                android:id="@+id/tvSinTareas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/sin_tareas_hoy"
                android:textSize="14sp"
                android:textColor="@color/secondary_text"
                android:textAlignment="center"
                android:padding="32dp"
                android:visibility="gone"/>

            <!-- RecyclerView de tareas -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerTareas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginBottom="16dp"
                tools:listitem="@layout/item_mantenimiento_card"/>

            <!-- SECCIÓN 3: MIS ESTADÍSTICAS DEL MES -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mis_estadisticas_mes"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/primary_text"
                android:layout_marginBottom="12dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:rowCount="2"
                    android:padding="16dp">

                    <!-- Stat 1: Completados -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_row="0"
                        android:layout_column="0"
                        android:layout_columnWeight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✅"
                            android:textSize="32sp"/>

                        <TextView
                            android:id="@+id/tvMisCompletados"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary"
                            android:layout_marginTop="4dp"
                            tools:ignore="HardcodedText"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/completados"
                            android:textSize="12sp"
                            android:textColor="@color/secondary_text"/>

                    </LinearLayout>

                    <!-- Stat 2: Calificación -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_row="0"
                        android:layout_column="1"
                        android:layout_columnWeight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⭐"
                            android:textSize="32sp"/>

                        <TextView
                            android:id="@+id/tvMiCalificacion"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.0"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="#FFC107"
                            android:layout_marginTop="4dp"
                            tools:ignore="HardcodedText"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/calificacion"
                            android:textSize="12sp"
                            android:textColor="@color/secondary_text"/>

                    </LinearLayout>

                    <!-- Stat 3: Eficiencia -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_row="1"
                        android:layout_column="0"
                        android:layout_columnWeight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📊"
                            android:textSize="32sp"/>

                        <TextView
                            android:id="@+id/tvMiEficiencia"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0%"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary"
                            android:layout_marginTop="4dp"
                            tools:ignore="HardcodedText"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/eficiencia"
                            android:textSize="12sp"
                            android:textColor="@color/secondary_text"/>

                    </LinearLayout>

                    <!-- Stat 4: A Tiempo -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_row="1"
                        android:layout_column="1"
                        android:layout_columnWeight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⏰"
                            android:textSize="32sp"/>

                        <TextView
                            android:id="@+id/tvATiempo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0/0"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="@color/success"
                            android:layout_marginTop="4dp"
                            tools:ignore="HardcodedText"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/a_tiempo"
                            android:textSize="12sp"
                            android:textColor="@color/secondary_text"/>

                    </LinearLayout>

                </GridLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- SECCIÓN 4: MI PRÓXIMA CITA -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mi_proxima_cita"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/primary_text"
                android:layout_marginBottom="12dp"/>

            <!-- Mensaje sin próxima cita -->
            <TextView
                android:id="@+id/tvSinProximaCita"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/sin_proximas_citas"
                android:textSize="14sp"
                android:textColor="@color/secondary_text"
                android:textAlignment="center"
                android:padding="32dp"
                android:visibility="gone"/>

            <!-- Card de próxima cita -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardProximaCita"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvProximaFecha"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mañana, 26/11/2025"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        tools:ignore="HardcodedText"/>

                    <TextView
                        android:id="@+id/tvProximaHora"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🕙 10:00 AM"
                        android:textSize="14sp"
                        android:textColor="@color/secondary_text"
                        android:layout_marginTop="4dp"
                        tools:ignore="HardcodedText"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider_color"
                        android:layout_marginVertical="12dp"/>

                    <TextView
                        android:id="@+id/tvProximaEquipo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💻 Impresora HP LaserJet"
                        android:textSize="15sp"
                        android:textColor="@color/primary_text"
                        android:textStyle="bold"
                        tools:ignore="HardcodedText"/>

                    <TextView
                        android:id="@+id/tvProximaCliente"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🏢 Consultores Asociados"
                        android:textSize="14sp"
                        android:textColor="@color/secondary_text"
                        android:layout_marginTop="4dp"
                        tools:ignore="HardcodedText"/>

                    <TextView
                        android:id="@+id/tvProximaUbicacion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📍 Centro Comercial, Local 5"
                        android:textSize="13sp"
                        android:textColor="@color/secondary_text"
                        android:layout_marginTop="4dp"
                        tools:ignore="HardcodedText"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnVerDetallesCita"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/ver_detalles"
                        android:layout_marginTop="12dp"
                        style="@style/Widget.MaterialComponents.Button.TextButton"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/white"
        android:elevation="8dp"
        app:menu="@menu/menu_bottom_navigation_tecnico"
        app:labelVisibilityMode="labeled"
        app:itemIconTint="@color/primary"
        app:itemTextColor="@color/primary"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>